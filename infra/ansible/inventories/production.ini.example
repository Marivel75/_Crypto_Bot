# Ansible Inventory for Production VPS
# Usage: cp production.ini.example production.ini && edit production.ini
# Then: ansible-playbook -i inventories/production.ini playbooks/provision.yml

[vps]
# Replace with your production VPS hostname or IP address
cryptobot-prod ansible_host=your-vps-hostname-or-ip.com ansible_user=root

[vps:vars]
# Override group variables here if needed
domain_name=your-domain.com
letsencrypt_email=your-email@example.com
deploy_user=deploy

# Example with IP:
# cryptobot-prod ansible_host=192.168.1.100 ansible_user=root
