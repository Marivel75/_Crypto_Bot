# Managed by Ansible — do not edit manually.
# Role: security | Template: jail.local.j2

[DEFAULT]
bantime  = {{ fail2ban_bantime }}
findtime = {{ fail2ban_findtime }}
maxretry = {{ fail2ban_maxretry_default }}
backend  = systemd
ignoreip = {{ fail2ban_ignoreip | join(' ') }}

[sshd]
enabled  = true
port     = 22
filter   = sshd
logpath  = /var/log/auth.log
maxretry = {{ fail2ban_maxretry_sshd }}
bantime  = {{ fail2ban_bantime }}

[nginx-http-auth]
enabled  = true
filter   = nginx-http-auth
logpath  = /var/log/nginx/error.log
maxretry = {{ fail2ban_maxretry_nginx_http_auth }}

[nginx-botsearch]
enabled  = true
filter   = nginx-botsearch
logpath  = /var/log/nginx/access.log
maxretry = {{ fail2ban_maxretry_nginx_botsearch }}
