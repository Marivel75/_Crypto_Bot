# Managed by Ansible — do not edit manually.
# Role: nginx | Template: nginx-proxy-params.conf.j2
# Include in proxy location blocks: include /etc/nginx/snippets/proxy-params.conf;

# ---------------------------------------------------------------------------
# WebSocket upgrade support
# ---------------------------------------------------------------------------
proxy_http_version      1.1;
proxy_set_header        Upgrade           $http_upgrade;
proxy_set_header        Connection        $connection_upgrade;

# ---------------------------------------------------------------------------
# Forwarded headers
# ---------------------------------------------------------------------------
proxy_set_header        Host              $host;
proxy_set_header        X-Real-IP         $remote_addr;
proxy_set_header        X-Forwarded-For   $proxy_add_x_forwarded_for;
proxy_set_header        X-Forwarded-Proto $scheme;
proxy_set_header        X-Forwarded-Host  $host;
proxy_set_header        X-Forwarded-Port  $server_port;

# ---------------------------------------------------------------------------
# Timeouts — generous for long-running requests (webhooks, streaming)
# ---------------------------------------------------------------------------
proxy_connect_timeout   60s;
proxy_send_timeout      300s;
proxy_read_timeout      300s;
send_timeout            300s;

# ---------------------------------------------------------------------------
# Buffering — disable for streaming/SSE responses
# ---------------------------------------------------------------------------
proxy_buffering         off;
proxy_request_buffering off;

# ---------------------------------------------------------------------------
# Body size limit
# ---------------------------------------------------------------------------
client_max_body_size    {{ nginx_client_max_body_size }};

# ---------------------------------------------------------------------------
# Hide upstream error details from clients
# ---------------------------------------------------------------------------
proxy_intercept_errors  off;
