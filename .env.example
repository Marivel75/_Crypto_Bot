# ========================================================
# Crypto Bot — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ========================================================

# --- Exchanges ---
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_API_SECRET=your_kraken_api_secret

COINBASE_API_KEY=your_coinbase_api_key
COINBASE_API_SECRET=your_coinbase_api_secret
COINBASE_API_PASSPHRASE=your_coinbase_api_passphrase

# --- Data providers ---
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key
CRYPTORANK_API_KEY=your_cryptorank_api_key

# --- Base de données ---
# SQLite (dev / Docker par défaut)
SQLITE_DB_PATH=data/processed/crypto_data.db
CRYPTO_BOT_DB_URL=sqlite:///data/processed/crypto_data.db

# PostgreSQL (production — décommenter si besoin)
# POSTGRES_USER=cryptobot
# POSTGRES_PASSWORD=your_password
# POSTGRES_DB=cryptobot
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# CRYPTO_BOT_DB_URL=postgresql://cryptobot:your_password@localhost:5432/cryptobot

# --- Docker / Frontend ---
# URL de l'API vue par le frontend (service Docker : http://api:8000)
API_URL=http://localhost:8000
