# ===================================================================
# Crypto Bot — Environment Variables
# ===================================================================
# SECURITY WARNING:
# - Copy this file to .env and fill in YOUR OWN values
# - NEVER commit .env to git
# - Use strong, random passwords (minimum 16 characters)
# - Change all CHANGE_ME values before running in any environment
# - Rotate secrets if accidentally exposed
# ===================================================================

# === Database (PostgreSQL / TimescaleDB) ===
POSTGRES_DB=cryptobot
POSTGRES_USER=cryptobot
# REQUIRED: Must be a strong password (min 16 chars, mixed case, numbers, symbols)
POSTGRES_PASSWORD=CHANGE_ME_strong_password_min_16_chars

# Derived from above — DO NOT CHANGE UNLESS YOU MODIFY docker-compose.yml
DATABASE_URL=postgresql://cryptobot:CHANGE_ME_strong_password_min_16_chars@timescaledb:5432/cryptobot

# === MinIO / S3-Compatible Storage ===
# REQUIRED: MinIO administrator credentials (min 8 chars each)
# SECURITY: Using default credentials (minioadmin/minioadmin) is DANGEROUS
MINIO_ROOT_USER=CHANGE_ME_your_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_password_min_16_chars
MINIO_ENDPOINT=http://minio:9000

# === FastAPI Backend ===
# REQUIRED: Secret key for JWT token signing (min 32 chars, random)
API_SECRET_KEY=CHANGE_ME_random_32_character_secret_key_for_jwt
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:8501"]
LOG_LEVEL=INFO
JWT_EXPIRATION_HOURS=24

# === Frontend (Streamlit) ===
API_URL=http://api:8000

# === CoinGecko API (Optional) ===
# Leave empty to use free public API (rate-limited)
# Get demo key at: https://www.coingecko.com/en/api/documentation
COINGECKO_API_KEY=

# === LLM Providers for Chat Assistant (Optional) ===
# Provide at least one to enable chatbot
# Get keys at: https://platform.openai.com/api-keys or https://console.anthropic.com
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === MLflow Experiment Tracking ===
MLFLOW_TRACKING_URI=http://mlflow:5000

# AWS/S3 credentials for MLflow artifacts (points to MinIO)
# MUST MATCH MINIO_ROOT_USER and MINIO_ROOT_PASSWORD above
AWS_ACCESS_KEY_ID=CHANGE_ME_your_minio_user
AWS_SECRET_ACCESS_KEY=CHANGE_ME_strong_password_min_16_chars

# === Grafana Monitoring Dashboard ===
# REQUIRED: Admin credentials for Grafana UI access
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_strong_password_min_16_chars

# ===================================================================
# INSTRUCTIONS FOR FIRST-TIME SETUP
# ===================================================================
# 1. Copy this file: cp .env.example .env
# 2. Replace all CHANGE_ME values with your own strong passwords
# 3. Run: docker-compose up -d
# 4. Access services:
#    - API: http://localhost:8000
#    - Frontend: http://localhost:8501
#    - Grafana: http://localhost:3000 (user: admin)
#    - MinIO: http://localhost:9001 (user: your_minio_user)
#    - MLflow: http://localhost:5000
# 5. Test database: docker-compose exec timescaledb psql -U cryptobot
# ===================================================================
