# ========================================================
# Crypto Bot — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ========================================================

# --- Exchanges ---
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_API_SECRET=your_kraken_api_secret

COINBASE_API_KEY=your_coinbase_api_key
COINBASE_API_SECRET=your_coinbase_api_secret
COINBASE_API_PASSPHRASE=your_coinbase_api_passphrase

# --- Data providers ---
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key
CRYPTORANK_API_KEY=your_cryptorank_api_key

# --- Base de données ---
# SQLite est le défaut (make run). Aucune variable nécessaire.
#
# Pour utiliser PostgreSQL :
#   1. Renseigner POSTGRES_URL ci-dessous
#   2. Lancer avec make run DB=postgres  (ou make collect DB=postgres, etc.)
#   3. Migrer les données existantes : make db-migrate
#
# Format : postgresql://utilisateur:motdepasse@hote:5432/nom_base
POSTGRES_URL=postgresql://user:password@localhost:5432/crypto_bot

# --- Docker / Frontend ---
# URL de l'API vue par le frontend (service Docker : http://api:8000)
API_URL=http://localhost:8000

# --- MLflow ---
# En local : http://localhost:5001 | En Docker : http://mlflow:5000
# (port 5000 réservé par AirPlay sur macOS)
MLFLOW_TRACKING_URI=http://localhost:5001

# --- Scheduler collecte ---
# Heure de collecte quotidienne (format HH:MM)
CRYPTO_BOT_SCHEDULE_TIME=08:00

# --- Alertes email ---
# Laisser vide pour désactiver les alertes
ALERT_EMAIL_TO=votre@email.com
ALERT_EMAIL_FROM=cryptobot@gmail.com
ALERT_EMAIL_PASSWORD=your_app_password
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
