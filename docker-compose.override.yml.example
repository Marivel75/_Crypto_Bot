# Development override for local development
# Usage: docker-compose will automatically apply this alongside docker-compose.yml
# This exposes all services to localhost and enables hot-reload

services:
  timescaledb:
    ports:
      - "5432:5432"  # Full exposure for local development

  minio:
    ports:
      - "9000:9000"  # API endpoint
      - "9001:9001"  # Console UI

  mlflow:
    ports:
      - "5000:5000"

  api:
    ports:
      - "8000:8000"
    volumes:
      - ./src/api:/app/src/api:cached
      - ./src/shared:/app/src/shared:cached
    environment:
      LOG_LEVEL: DEBUG

  frontend:
    ports:
      - "8501:8501"
    volumes:
      - ./src/frontend:/app/src/frontend:cached
    environment:
      STREAMLIT_SERVER_HEADLESS: "false"
      API_URL: http://localhost:8000

  etl-worker:
    volumes:
      - ./src/etl:/app/src/etl:cached
      - ./src/shared:/app/src/shared:cached
    environment:
      LOG_LEVEL: DEBUG

  ml-worker:
    volumes:
      - ./src/ml:/app/src/ml:cached
      - ./src/shared:/app/src/shared:cached
    environment:
      LOG_LEVEL: DEBUG

  prometheus:
    ports:
      - "9090:9090"

  grafana:
    ports:
      - "3000:3000"

  postgres-exporter:
    ports:
      - "9187:9187"

  nginx-exporter:
    ports:
      - "9113:9113"

  # Node exporter — Linux only for development
  node-exporter:
    image: prom/node-exporter:v1.8.0
    restart: unless-stopped
    command:
      - "--path.rootfs=/host"
      - "--path.procfs=/host/proc"
      - "--path.sysfs=/host/sys"
      - "--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc)($$|/)"
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro
    ports:
      - "9100:9100"
    networks:
      - backend-net
    deploy:
      resources:
        limits:
          memory: 64M

  # cAdvisor — Docker container metrics (Linux only)
  cadvisor:
    image: gcr.io/cadvisor/cadvisor:v0.49.1
    restart: unless-stopped
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
      - /dev/disk/:/dev/disk:ro
    ports:
      - "8081:8080"
    privileged: true
    devices:
      - /dev/kmsg:/dev/kmsg
    networks:
      - backend-net
    deploy:
      resources:
        limits:
          memory: 256M
